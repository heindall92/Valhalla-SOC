{
  "name": "valhalla-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron-main.js",
  "scripts": {
    "desktop": "cross-env NODE_ENV=development electron .",
    "build:exe": "npm run build && electron-builder --win",
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3000"
  },
  "build": {
    "appId": "com.valhalla.soc",
    "productName": "Valhalla SOC",
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "files": [
      "app/dist/**/*",
      "electron-main.js"
    ]
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.4.6",
    "@mui/material": "^6.4.6",
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-grid-layout": "^2.2.3",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.8.3",
    "vite": "^6.2.2"
  }
}
