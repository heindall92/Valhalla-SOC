# Credenciales — NUNCA subir a Git
.env

# Claude Code internal files
.claude/
.remember/
.playwright-mcp/

# SSL certificates (sensitive)
config/wazuh_indexer_ssl_certs/*.pem
config/wazuh_indexer_ssl_certs/*.key

# Docker volumes data
wazuh-*-data/

# Python cache
__pycache__/
*.pyc
*.pyo

# Node.js
frontend/node_modules/
backend/node_modules/
backend/package-lock.json
frontend/.vite/
*.node

# Large binary/image files (root only)
imagen.png
# Allow documentation screenshots
!docs/img/*.png

# Databases (runtime data)
backend/*.db
backend/*.db-shm
backend/*.db-wal

# Logs
*.log

# Windows temp
Thumbs.db
desktop.ini

# Exclusiones extra
MedHomologa-Pro/node_modules/
MedHomologa-Pro/.next/

# Build outputs
frontend/app/dist/
frontend/dist_electron/
dist/
dist_electron/

# Archivos personales de automatizacion (local only)
# Estos scripts son para uso personal del desarrollador principal
# No deben subirse al repo compartido
LIMPIEZA_SEGURA.bat
verificar-requisitos.bat
detener-todo.bat
ORIENTACIONES.md
