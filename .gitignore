# ═══════════════════════════════════════════════════════════════════════════════
# Valhalla SOC — .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ── Credenciales y secretos ───────────────────────────────────────────────────
.env
.env.*.local
credenciales.txt

# ── Claude / AI internal files ────────────────────────────────────────────────
.claude/
.remember/
.playwright-mcp/

# ── SSL certificates (sensitive) ─────────────────────────────────────────────
config/wazuh_indexer_ssl_certs/*.pem
config/wazuh_indexer_ssl_certs/*.key

# ── Docker volumes data ──────────────────────────────────────────────────────
wazuh-*-data/

# ── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.ruff_cache/
.mypy_cache/
.pytest_cache/

# ── Node.js ──────────────────────────────────────────────────────────────────
frontend/node_modules/
backend/node_modules/
backend/package-lock.json
frontend/.vite/
*.node

# ── Large binary/image files (root only) ─────────────────────────────────────
imagen.png
# Allow documentation screenshots
!docs/img/*.png

# ── Databases (runtime data) ─────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal
backend/backups/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log

# ── Coverage & test artifacts ────────────────────────────────────────────────
coverage/
htmlcov/
playwright-report/
test-results/

# ── SBOM & security scan outputs ────────────────────────────────────────────
sbom.json
*.spdx.json

# ── Build outputs ────────────────────────────────────────────────────────────
frontend/app/dist/
frontend/dist_electron/
dist/
dist_electron/

# ── Windows temp ─────────────────────────────────────────────────────────────
Thumbs.db
desktop.ini

# ── Exclusiones extra (proyectos locales) ────────────────────────────────────
MedHomologa-Pro/node_modules/
MedHomologa-Pro/.next/

# ── Archivos personales de automatización (local only) ───────────────────────
LIMPIEZA_SEGURA.bat
verificar-requisitos.bat
detener-todo.bat
ORIENTACIONES.md

# ── Uploads (runtime data, not versioned) ────────────────────────────────────
backend/uploads/
