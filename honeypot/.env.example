# ═══════════════════════════════════════════════════════════
# Valhalla SOC — Honeypot (Cowrie) — Variables de entorno
#
# Copia este fichero a .env y ajusta lo que necesites.
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════

# Puerto del host donde se publica SSH de Cowrie.
# Si quieres que Cowrie reciba tráfico "real" de internet,
# mapea el 22 externo a este 2222 con iptables/UFW/nftables,
# o pon directamente 22 aquí (requiere privilegios).
COWRIE_SSH_PORT=2222

# Puerto del host donde se publica Telnet de Cowrie
COWRIE_TELNET_PORT=2223

# Nombre del contenedor (usado por el backend para logs/docker API)
COWRIE_CONTAINER_NAME=valhalla-cowrie

# Ruta absoluta del volumen nombrado donde caen los logs JSON
# (no se suele cambiar, lo deja docker):
#   /var/lib/docker/volumes/valhalla_cowrie_logs/_data/cowrie.json
