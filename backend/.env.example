# ============================================================
# VALHALLA SOC — Variables de entorno para producción
# Copia este fichero a .env y rellena los valores reales
# NUNCA subas .env a git
# ============================================================

# Entorno (development | production)
NODE_ENV=production

# Puerto del servidor Express
PORT=3000

# Secreto JWT — genera uno con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_LARGO_Y_ALEATORIO

# Contraseña del admin inicial (solo se usa la primera vez que arranca sin BD)
ADMIN_PASSWORD=CAMBIA_ESTO

# OpenSearch / Wazuh Indexer
INDEXER_URL=https://localhost:9200
INDEXER_USERNAME=admin
INDEXER_PASSWORD=CAMBIA_ESTO

# Wazuh Manager API
WAZUH_API_URL=https://localhost:55000
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=CAMBIA_ESTO

# VirusTotal API — Registro gratuito en https://www.virustotal.com/gui/join-us
# Plan FREE: 500 peticiones/día, 4 peticiones/minuto — suficiente para análisis manual
VIRUSTOTAL_API_KEY=PEGA_AQUI_TU_API_KEY
