# ═══════════════════════════════════════════════════════════════════════════════
# Valhalla SOC — Variables de Entorno
# Copiar este archivo a .env y rellenar los valores reales
# NUNCA subir .env a Git
# ═══════════════════════════════════════════════════════════════════════════════

# ── Backend FastAPI ───────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-min-32-chars
DATABASE_URL=postgresql+psycopg://valhalla:valhalla@postgres:5432/valhalla
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
BACKEND_PORT=8000

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Wazuh Manager API ────────────────────────────────────────────────────────
WAZUH_API_URL=https://wazuh.manager:55000
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=replace-with-real-pass

# ── OpenSearch / Wazuh Indexer ────────────────────────────────────────────────
OPENSEARCH_URL=https://wazuh.indexer:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=replace-with-real-pass
INDEXER_USERNAME=admin
INDEXER_PASSWORD=replace-with-real-pass

# ── Wazuh Dashboard ──────────────────────────────────────────────────────────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=replace-with-real-pass
OPENSEARCH_DASHBOARDS_USER=kibanaserver
OPENSEARCH_DASHBOARDS_PASSWORD=replace-with-real-pass
WAZUH_DASHBOARD_URL=https://localhost

# ── Ollama (IA Local) ────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_TEMPERATURE=0
OLLAMA_TIMEOUT_SECONDS=45

# ── Threat Intelligence ──────────────────────────────────────────────────────
VIRUSTOTAL_API_KEY=
OTX_API_KEY=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=valhalla
POSTGRES_USER=valhalla
POSTGRES_PASSWORD=replace-with-real-pass
POSTGRES_PORT=5432

# ── React Dashboard ──────────────────────────────────────────────────────────
DASHBOARD_PORT=3000
VITE_API_BASE_URL=

# ── Security Settings ────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO
EVIDENCE_DIR=/app/uploads/evidence
MAX_UPLOAD_SIZE_MB=10
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_VT=10/minute
RATE_LIMIT_THREAT_MAP=6/minute
GEO_CACHE_TTL_DAYS=30
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=strict
CSRF_ENABLED=true
