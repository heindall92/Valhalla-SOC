# ═══════════════════════════════════════════════════════════
# Valhalla SOC — Variables de Entorno
# Copiar este archivo a .env y rellenar los valores reales
# NUNCA subir .env a Git
# ═══════════════════════════════════════════════════════════

# Credenciales Wazuh Indexer (OpenSearch admin)
INDEXER_USERNAME=admin
INDEXER_PASSWORD=admin

# Credenciales Wazuh Dashboard
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=admin

# Credenciales Wazuh API (plugin UI)
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=wazuh-wui

# Credenciales internas de OpenSearch Dashboards (no cambiar salvo regeneración de certs)
OPENSEARCH_DASHBOARDS_USER=kibanaserver
OPENSEARCH_DASHBOARDS_PASSWORD=kibanaserver

# Ollama (wazuh manager + backend fastapi)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b-instruct

# fastapi backend
BACKEND_PORT=8000
DATABASE_URL=postgresql+psycopg://valhalla:valhalla@postgres:5432/valhalla
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.46.1:3000,http://192.168.1.17:3000
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_TEMPERATURE=0
OLLAMA_TIMEOUT_SECONDS=45

# postgres
POSTGRES_DB=valhalla
POSTGRES_USER=valhalla
POSTGRES_PASSWORD=valhalla
POSTGRES_PORT=5432

# react dashboard
DASHBOARD_PORT=3000
VITE_API_BASE_URL=

# URLs (dejar como están para entorno local)
WAZUH_DASHBOARD_URL=https://localhost
WAZUH_API_URL=https://localhost:55000
INDEXER_URL=https://localhost:9200
